# Database — Supabase PostgreSQL (aanbevolen voor Vercel productie)
# Gebruik in productie bij voorkeur de Supabase direct URL (poort 5432) als DATABASE_URL
# (werkt zowel voor runtime als Prisma migraties).
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"
# Alleen nodig als je bewust seeddata in productie wilt draaien (eenmalig):
# ALLOW_PROD_SEED="true"
# Optioneel: zet op true als je tijdens deploy automatisch demo-data wilt seeden.
# SEED_ON_DEPLOY="false"

# NextAuth — verander naar een sterk willekeurig geheim in productie
NEXTAUTH_SECRET="verander-dit-naar-een-sterk-willekeurig-geheim-van-32-tekens"
NEXTAUTH_URL="http://localhost:3000"
