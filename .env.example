# Database — Supabase PostgreSQL (aanbevolen voor Vercel productie)
# Gebruik in productie de Supabase pooled URL (poort 6543) voor DATABASE_URL
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Gebruik DIRECT_URL voor migraties (directe verbinding, poort 5432)
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# NextAuth — verander naar een sterk willekeurig geheim in productie
NEXTAUTH_SECRET="verander-dit-naar-een-sterk-willekeurig-geheim-van-32-tekens"
NEXTAUTH_URL="http://localhost:3000"
